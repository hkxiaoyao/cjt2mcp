# ===== 平台级机密（仅这些进 env；租户畅捷通凭据走后台录入并加密入库）=====

# AES-GCM 主密钥：用于加密租户的 appSecret / 消息秘钥 / certificate / token
# 生成方式：python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=

# 管理员初始账号（首次启动自动创建；创建后可在后台改密）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Session 签名密钥
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# 对外访问域名（用于生成 webhook / MCP 地址提示，不含协议后缀）
PUBLIC_BASE_URL=https://mcp.example.com

# SQLite 数据库文件路径
DB_PATH=data/cjt2mcp.db

# Session 有效期（分钟）
SESSION_MAX_AGE_MINUTES=480
